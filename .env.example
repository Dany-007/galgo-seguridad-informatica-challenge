# Copia este archivo a ".env" y reemplaza todos los valores antes de levantar el laboratorio.
# NUNCA subir el archivo ".env" real a un repositorio (ver .gitignore).

NODE_ENV=production
PORT=3000

# --- Base de datos ---
POSTGRES_USER=galo_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=galo_customers
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://galo_app:CHANGE_ME_STRONG_PASSWORD@postgres:5432/galo_customers?schema=public

# --- JWT ---
# Generar con: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_BYTE_RANDOM_HEX
JWT_EXPIRES_IN=15m

# --- Cifrado de campos sensibles (envelope encryption simulada) ---
# Master Key (KEK) de 32 bytes en base64. Generar con: openssl rand -base64 32
MASTER_KEK_BASE64=CHANGE_ME_32_BYTE_BASE64_KEY

# --- Proveedor externo ---
PROVIDER_API_URL=https://62433a7fd126926d0c5d296b.mockapi.io/api/v1/usuarios
INGESTION_CRON=*/30 * * * *

# --- Usuario admin inicial (solo se usa en el seed) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_ANALYST_USERNAME=analyst
SEED_ANALYST_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_VIEWER_USERNAME=viewer
SEED_VIEWER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
